    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "prettier": "^3.0.3",
    "ts-jest": "^29.1.1",
    "turbo": "^2.5.8",
    "typescript-eslint": "^8.57.0",
    "vite-plugin-pwa": "^1.2.0"
